---
// CPL leadership team, restyled to the grand-hotel system. Photos are
// forest-tinted grayscale that warm on hover. The three-word value lines
// (e.g. "Vision. Communication. Leadership.") map onto the tag pills.
import ron from "../assets/ron.png";
import wesley from "../assets/wesley.png";
import jonathan from "../assets/jonathan.png";

// Cliff Suljak leads the "Meet your procurement officer" section earlier on
// the page, so he is intentionally not repeated in this roster.
const team = [
  {
    photo: ron, name: "Ron Hansen", role: "CEO",
    bio: "With a passion for empowering people and a track record of high-impact execution, I transform bold ideas into thriving realities through visionary leadership, clear communication, and strategic relationship-building.",
    tags: ["Vision", "Communication", "Leadership"],
  },
  {
    photo: wesley, name: "Wesley Bartlett Jr", role: "COO",
    bio: "Wesley is passionate about transformation and discipleship of Nations through Revelation of Identity & Sonship to bring Revival and Reformation to all spheres of society establishing Unity in Christ.",
    tags: ["Visionary", "Creative", "Entrepreneur"],
  },
  {
    photo: jonathan, name: "Jonathan Grinko", role: "Director of Systems & Business Development",
    bio: "Jonathan builds the internal systems behind sales, operations, and client delivery, including CRM workflows, automation, and documentation. His focus is simple: repeatable processes that protect quality, improve follow through, and make growth sustainable.",
    tags: ["Integrity", "Family", "Community"],
  },
];
---

<section class="section team" id="team" aria-labelledby="team-title">
  <div class="container">
    <div class="team__head reveal">
      <h2 class="team__title" id="team-title">Who reads your meter.</h2>
      <p class="team__lede lede">
        Not a network of strangers. A team with verified credentials at the
        highest levels of government, infrastructure, and commercial energy,
        pointed at your hotel.
      </p>
    </div>

    <div class="team__grid">
      {
        team.map((m, i) => (
          <article class="team__card reveal" style={`--i: ${i}`}>
            <img
              class="team__photo bio-photo"
              src={m.photo.src}
              width={m.photo.width}
              height={m.photo.height}
              loading="lazy"
              alt={`${m.name}, ${m.role}`}
            />
            <div class="team__body">
              <h3 class="team__name">{m.name}</h3>
              <p class="team__role">{m.role}</p>
              <p class="team__bio">{m.bio}</p>
              <div class="team__tags">
                {m.tags.map((t) => (
                  <span class="team__tag">{t}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .team { border-top: 1px solid var(--line); }
  /* the team gets a wider stage than the prose sections */
  .team :global(.container),
  .team .container {
    max-width: 88rem;
  }
  .team__head { max-width: 54rem; }
  .team__title { font-size: var(--step-3); max-width: 16ch; }
  .team__lede { margin-top: var(--space-m); }

  /* explicit 1 / 2 / 4 columns: a 3+1 orphan row is never allowed */
  .team__grid {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  @media (min-width: 620px) {
    .team__grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 1000px) {
    .team__grid { grid-template-columns: repeat(3, 1fr); }
  }
  .team__card {
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.35s ease, transform 0.45s var(--ease-out-quart);
  }
  .team__card:hover {
    border-color: rgba(194, 163, 104, 0.5);
    transform: translateY(-3px);
  }
  /* full original framing at every width: scale, never crop.
     grayscale->color handled by the shared .bio-photo treatment */
  .team__photo {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (prefers-reduced-motion: reduce) {
    .team__card { transition: none; }
  }
  .team__body { padding: 1.3rem 1.4rem 1.5rem; }
  .team__name {
    font-size: var(--step-1);
    letter-spacing: -0.01em;
  }
  .team__role {
    margin-top: 0.2rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--gold-text);
  }
  .team__bio {
    margin-top: var(--space-s);
    font-size: var(--step--1);
    line-height: 1.6;
    color: var(--body);
  }
  .team__tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: var(--space-s); }
  .team__tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.04em;
    color: var(--muted);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.3em 0.75em;
  }
</style>
